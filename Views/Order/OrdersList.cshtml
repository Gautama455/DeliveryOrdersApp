@using DeliveryOrdersApp.Models
@model IEnumerable<DeliveryOrdersApp.Models.Order>

@{
    ViewData["Title"] = "Список заказов";
}

<link rel="stylesheet" href="~/css/OrderListStyle.css" asp-append-version="true" />

<div class="orders-header">
    <h2>Список заказов</h2>
    <a asp-action="CreateOrder" class="new-order-button">Новый заказ</a>
</div>

<div class="orders-table-container">
    <table class="orders-table">
        <thead>
            <tr>
                <th>Номер</th>
                <th>Откуда</th>
                <th>Куда</th>
                <th>Вес кг.</th>
                <th>Дата забора</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Order order in Model)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.SenderCity, @order.SenderAdress</td>
                    <td>@order.RecipientCity, @order.RecipientAdress</td>
                    <td>@order.Weight</td>
                    <td>@order.PickupDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-controller="Order" asp-action="Details"
                            asp-route-orderNumber="@order.OrderNumber"
                            class="btn-details">
                            Детали
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>